# ALPTHERM-ICON Archiv — S3-Object-Storage-Konfiguration (Plan §9.6)
#
# Kopiere diese Datei nach `data/archive.env` und trage die Hetzner-
# Object-Storage-Credentials ein. `archive.env` ist in .gitignore —
# Secrets bleiben lokal, nie committen.
#
# Format wie data/monitoring.env: KEY=VALUE pro Zeile, '#' für
# Kommentare, einfache/doppelte Quotes werden entfernt, keine
# shell-style expansion.
#
# Sind die S3-Keys leer/unkonfiguriert, fällt der Archiv-Code auf
# reinen Lokalbetrieb zurück (data/archive/) — das S3-Backend wird
# nur aktiv, wenn Endpoint + Keys + beide Buckets gesetzt sind.

# Hetzner Object Storage, S3-kompatibel. Endpoint pro Region:
#   nbg1 → https://nbg1.your-objectstorage.com
#   fsn1 → https://fsn1.your-objectstorage.com
#   hel1 → https://hel1.your-objectstorage.com
ALPTHERM_S3_ENDPOINT=https://nbg1.your-objectstorage.com
ALPTHERM_S3_REGION=nbg1

ALPTHERM_S3_ACCESS_KEY=
ALPTHERM_S3_SECRET_KEY=

# Zwei private Buckets (Plan §9.6):
#   *-raw  : append-only Roh-GRIB2, Bucket MIT Object Lock (Governance).
#   *-zarr : abgeleitetes Zarr-Analysearchiv, OHNE Lock (tägliches Append).
ALPTHERM_S3_RAW_BUCKET=alptherm-raw
ALPTHERM_S3_ZARR_BUCKET=alptherm-zarr

# Governance-Retention pro hochgeladenem Roh-File, in Tagen. Schützt die
# unwiederbringliche Rohschicht gegen versehentliches Löschen / fehlerhafte
# Aufräum-Skripte; Admins können im Governance-Modus bewusst übersteuern.
# Tunbar — muss nicht maximal sein (Plan §9.6).
ALPTHERM_S3_RAW_RETENTION_DAYS=365
